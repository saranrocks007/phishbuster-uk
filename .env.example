# ============================================================
# PhishBuster UK — Environment configuration
# Copy to `.env` and fill with your values. Never commit `.env`.
# ============================================================

# --- Application ---
APP_ENV=development              # development | staging | production
LOG_LEVEL=INFO
PB_DATA_DIR=./data
PB_TIMEZONE=Europe/London

# --- Database ---
DATABASE_URL=sqlite:///./data/phishbuster.db
# For production: DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/phishbuster

# --- Microsoft 365 / Graph API ---
# Register an app in Entra ID with Mail.Read + Mail.ReadWrite + MailboxSettings.Read
M365_TENANT_ID=00000000-0000-0000-0000-000000000000
M365_CLIENT_ID=00000000-0000-0000-0000-000000000000
M365_CLIENT_SECRET=CHANGE_ME
M365_TARGET_MAILBOX=soc-inbox@yourcompany.co.uk
M365_POLL_INTERVAL_SECONDS=60

# --- Classifier ---
MODEL_PATH=./data/classifier.joblib
CLASSIFIER_THRESHOLD=0.65        # >= threshold => phishing verdict
UK_LURE_WEIGHT=0.25              # weight added to score if UK lure detected

# --- Response automation ---
ENABLE_AUTO_QUARANTINE=true
ENABLE_TICKETING=true
QUARANTINE_FOLDER=PhishBusterQuarantine

# --- Ticketing (choose one) ---
TICKETING_BACKEND=jira           # jira | servicenow | stdout
JIRA_URL=https://yourco.atlassian.net
JIRA_USER=soc@yourco.co.uk
JIRA_API_TOKEN=CHANGE_ME
JIRA_PROJECT_KEY=SOC

# --- Alerting ---
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# --- NCSC SERS bridge (optional) ---
ENABLE_NCSC_SERS_FORWARDING=false
NCSC_SERS_ADDRESS=report@phishing.gov.uk

# --- Dashboard ---
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
DASHBOARD_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# ---------- Threat intelligence (all OPTIONAL — engine works without them) ----------
ENABLE_THREAT_INTEL=false
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
URLHAUS_AUTH_KEY=                      # optional, abuse.ch URLhaus
PHISHTANK_USERNAME=                    # optional, phishtank.org
THREAT_INTEL_CACHE_TTL_HOURS=24

# ---------- Domain age (WHOIS) ----------
ENABLE_DOMAIN_AGE_CHECK=true
DOMAIN_AGE_RECENT_DAYS=30              # ≤ this = "newly registered" finding

# ---------- Live URL sandbox ----------
ENABLE_URL_SANDBOX=false               # off by default — visits URLs
SANDBOX_TIMEOUT_SECONDS=8
SANDBOX_MAX_REDIRECTS=4
SANDBOX_USER_AGENT=Mozilla/5.0 (compatible; PhishBuster-Sandbox/1.0)
URLSCAN_API_KEY=                       # optional — urlscan.io for safer external sandboxing

# ---------- Attachment scanning ----------
ENABLE_YARA_SCANNING=true
YARA_RULES_DIR=./config/yara
ENABLE_CLAMAV=false                    # set true if clamd reachable
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310

# ---------- BEC / sender baseline ----------
ENABLE_BEC_DETECTOR=true
BEC_BASELINE_MIN_MESSAGES=5            # need ≥ N prior msgs from sender to score
